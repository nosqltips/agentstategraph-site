<script>
(function() {
  'use strict';
  // Scroll reveals
  var els = document.querySelectorAll('[data-reveal]');
  if (els.length) {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) { if (e.isIntersecting) { e.target.classList.add('revealed'); obs.unobserve(e.target); } });
    }, { threshold: 0.15 });
    els.forEach(function(el) { obs.observe(el); });
  }
  // Nav
  var nav = document.querySelector('.nav'), hero = document.querySelector('.hero');
  if (nav && hero) {
    var hb = hero.offsetTop + hero.offsetHeight;
    window.addEventListener('scroll', function() { nav.classList.toggle('visible', window.scrollY > hb - 60); }, { passive: true });
  }
  // Terminal typing
  var tb = document.getElementById('terminal-body');
  if (tb) {
    var played = false;
    var cmds = [
      {p:'$ ',t:'git clone https://github.com/nosqltips/AgentStateGraph',d:25},
      {p:'$ ',t:'cd AgentStateGraph && cargo build --release -p agentstategraph-mcp',d:20},
      {p:'$ ',t:'cargo run --release -p agentstategraph-mcp -- --http',d:25},
      {o:'AgentStateGraph Server v0.5.0-beta.1\nStorage: ./agentstategraph.db\nHTTP API listening on http://0.0.0.0:3001',w:400},
      {p:'$ ',t:'curl http://localhost:3001/api/stats/main',d:30},
    ];
    function type() {
      if (played) return; played = true; tb.textContent = '';
      var delay = 0;
      cmds.forEach(function(c) {
        if (c.o) {
          delay += c.w||300;
          var d=delay;
          setTimeout(function() { var s=document.createElement('span'); s.className='output'; s.textContent=c.o+'\n'; tb.appendChild(s); }, d);
          delay += 100;
        } else {
          var pd=delay;
          setTimeout(function() { var s=document.createElement('span'); s.className='prompt'; s.textContent=c.p; tb.appendChild(s); }, pd);
          delay += 50;
          c.t.split('').forEach(function(ch,i) {
            var cd=delay+i*(c.d||30);
            setTimeout(function() { var s=document.createElement('span'); s.className='cmd'; s.textContent=ch; tb.appendChild(s); }, cd);
          });
          delay += c.t.length*(c.d||30)+200;
          var nd=delay;
          setTimeout(function() { tb.appendChild(document.createTextNode('\n')); }, nd);
          delay += 50;
        }
      });
      setTimeout(function() { var cur=document.createElement('span'); cur.className='cursor'; cur.textContent='\u00A0'; tb.appendChild(cur); }, delay+100);
    }
    var to = new IntersectionObserver(function(e) { if(e[0].isIntersecting){type();to.disconnect();} }, {threshold:0.4});
    to.observe(tb);
  }
})();
</script>
